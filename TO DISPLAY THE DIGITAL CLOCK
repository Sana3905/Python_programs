*** TO DISPLAY THE DIGITAL CLOCK ***

import time
import sys
h=12
m=14
s=0
while True:
    sys.stdout.write("\r{:02d} : {:02d} : {:02d}".format(h,m,s))
    sys.stdout.flush()
    time.sleep(1)

    s=s+1
    if s==60:
        s=0
        m=m+1
    if m==13:
        m=0
        s=0
        h=h+1
    if h==13:
        s=0
        h=0
        m=0



~ Output:  12:17:25    (the time [h,m,s] keeps on changing until we stop it)
