*** STUDENT AVERAGE MARKS CALCULATION USING LISTS IN PYTHON ***

names=["Raju","Pavi","Rose","jaanu","Abhi"]
marks=[[20,30,40],[44,55,66],[77,88,99],[45,55,65],[90,78,98]]
for i in range(5):
    a=sum(marks[i])//3
    print("{} . {} has scored {}".format(i+1,names[i],a))



